{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/home.js":    { "memory": 256, "maxDuration": 20 },
    "api/detail.js":  { "memory": 256, "maxDuration": 20 },
    "api/episode.js": { "memory": 256, "maxDuration": 20 },
    "api/search.js":  { "memory": 256, "maxDuration": 20 },
    "api/explore.js": { "memory": 256, "maxDuration": 20 },
    "api/genres.js":  { "memory": 256, "maxDuration": 20 },
    "api/proxy.js":   { "memory": 512, "maxDuration": 30 },
    "api/debug.js":   { "memory": 256, "maxDuration": 20 }
  }
}
