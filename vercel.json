{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/terbaru.js":  { "memory": 256, "maxDuration": 20 },
    "api/detail.js":   { "memory": 256, "maxDuration": 20 },
    "api/search.js":   { "memory": 256, "maxDuration": 20 },
    "api/schedule.js": { "memory": 256, "maxDuration": 20 },
    "api/stream.js":   { "memory": 256, "maxDuration": 30 },
    "api/poster.js":   { "memory": 256, "maxDuration": 20 }
  }
}
